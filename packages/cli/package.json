{
  "name": "@loopcod/ui",
  "version": "0.1.0",
  "description": "CLI for Loopcod UI - SaaS-focused React components",
  "license": "MIT",
  "author": "Loopcod <hello@loopcod.in>",
  "repository": {
    "type": "git",
